<div class="persona-pipeline">
<svg width="100%" viewBox="0 0 700 320" xmlns="http://www.w3.org/2000/svg">
<defs>
  <marker id="pp-arr" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="5" markerHeight="5" orient="auto">
    <path d="M2 2L8 5L2 8" fill="none" stroke="context-stroke" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
  </marker>
</defs>

<style>
  @keyframes pp-flow { to { stroke-dashoffset: -20; } }
  .pp-anim { animation: pp-flow 1.4s linear infinite; }
</style>

<!-- Section labels -->
<text x="110" y="22" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="9" font-weight="600" fill="var(--pp-dim)" letter-spacing="0.08em">데이터 수집</text>
<text x="350" y="22" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="9" font-weight="600" fill="var(--pp-dim)" letter-spacing="0.08em">페르소나 주입</text>
<text x="590" y="22" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="9" font-weight="600" fill="var(--pp-dim)" letter-spacing="0.08em">에이전트 통신</text>

<!-- LEFT COLUMN: Data Collection -->

<!-- 의도적 기록 (blue) -->
<rect x="30" y="50" width="160" height="58" rx="10" fill="var(--pp-blue-bg)" stroke="var(--pp-blue)" stroke-width="1.5"/>
<text x="110" y="74" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="12" font-weight="600" fill="var(--pp-blue-text)">의도적 기록</text>
<text x="110" y="94" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="9" fill="var(--pp-dim)">일기, 메모, 블로그</text>

<!-- 무의식적 흔적 (brown) -->
<rect x="30" y="140" width="160" height="58" rx="10" fill="var(--pp-brown-bg)" stroke="var(--pp-brown)" stroke-width="1.5"/>
<text x="110" y="164" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="12" font-weight="600" fill="var(--pp-brown-text)">무의식적 흔적</text>
<text x="110" y="184" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="9" fill="var(--pp-dim)">검색, 시청, 구매, 카톡</text>

<!-- MIDDLE COLUMN: Persona Injection -->

<!-- Fine-tuning (purple) -->
<rect x="270" y="50" width="160" height="58" rx="10" fill="var(--pp-purple-bg)" stroke="var(--pp-purple)" stroke-width="1.5"/>
<text x="350" y="74" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="12" font-weight="600" fill="var(--pp-purple-text)">Fine-tuning</text>
<text x="350" y="94" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="9" fill="var(--pp-dim)">말투 · 가치관 · 사고방식</text>

<!-- RAG (purple) -->
<rect x="270" y="140" width="160" height="58" rx="10" fill="var(--pp-purple-bg)" stroke="var(--pp-purple)" stroke-width="1.5"/>
<text x="350" y="164" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="12" font-weight="600" fill="var(--pp-purple-text)">RAG</text>
<text x="350" y="184" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="9" fill="var(--pp-dim)">구체적 기억 · 사실 · 경험</text>

<!-- 망각 엔진 (green) -->
<rect x="280" y="224" width="140" height="52" rx="8" fill="var(--pp-green-bg)" stroke="var(--pp-green)" stroke-width="1.2"/>
<text x="350" y="246" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="11" font-weight="600" fill="var(--pp-green-text)">망각 엔진</text>
<text x="350" y="264" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="7.5" fill="var(--pp-dim)">decay · TTL · consolidation</text>

<!-- RIGHT COLUMN: Agent Communication -->

<!-- 페르소나 에이전트 (accent) -->
<rect x="510" y="95" width="170" height="62" rx="10" fill="var(--pp-accent-bg)" stroke="var(--pp-accent)" stroke-width="1.8"/>
<text x="595" y="122" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="13" font-weight="700" fill="var(--pp-accent-text)">페르소나 에이전트</text>
<text x="595" y="142" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="9" fill="var(--pp-dim)">digital twin</text>

<!-- Protocol labels -->
<rect x="520" y="180" width="42" height="20" rx="4" fill="var(--pp-inner)" stroke="var(--pp-accent)" stroke-width="0.8"/>
<text x="541" y="194" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="8" font-weight="600" fill="var(--pp-accent-text)">MCP</text>

<rect x="570" y="180" width="42" height="20" rx="4" fill="var(--pp-inner)" stroke="var(--pp-accent)" stroke-width="0.8"/>
<text x="591" y="194" text-anchor="middle" font-family="'SF Mono', 'Consolas', monospace" font-size="8" font-weight="600" fill="var(--pp-accent-text)">A2A</text>

<!-- Dashed lines from protocols down to 다른 에이전트 -->
<line x1="541" y1="200" x2="541" y2="224" stroke="var(--pp-accent)" stroke-width="0.8" stroke-dasharray="4 3"/>
<line x1="591" y1="200" x2="591" y2="224" stroke="var(--pp-accent)" stroke-width="0.8" stroke-dasharray="4 3"/>

<!-- 다른 에이전트 (dimmed) -->
<rect x="525" y="224" width="140" height="42" rx="8" fill="var(--pp-inner)" stroke="var(--pp-dim)" stroke-width="1" stroke-dasharray="5 3"/>
<text x="595" y="250" text-anchor="middle" font-family="'Pretendard', -apple-system, sans-serif" font-size="11" fill="var(--pp-dim)">다른 에이전트</text>

<!-- ARROWS -->

<!-- 의도적 기록 → Fine-tuning (solid, animated) -->
<line x1="190" y1="79" x2="268" y2="79" stroke="var(--pp-blue)" stroke-width="1.2" stroke-dasharray="6 4" class="pp-anim" marker-end="url(#pp-arr)"/>

<!-- 무의식적 흔적 → RAG (solid, animated) -->
<line x1="190" y1="169" x2="268" y2="169" stroke="var(--pp-brown)" stroke-width="1.2" stroke-dasharray="6 4" class="pp-anim" marker-end="url(#pp-arr)"/>

<!-- Fine-tuning → 페르소나 에이전트 (solid, animated) -->
<path d="M430 79 L470 79 L470 116 L508 116" fill="none" stroke="var(--pp-purple)" stroke-width="1.2" stroke-dasharray="6 4" class="pp-anim" marker-end="url(#pp-arr)"/>

<!-- RAG → 페르소나 에이전트 (solid, animated) -->
<path d="M430 169 L470 169 L470 136 L508 136" fill="none" stroke="var(--pp-purple)" stroke-width="1.2" stroke-dasharray="6 4" class="pp-anim" marker-end="url(#pp-arr)"/>

<!-- 망각 엔진 → 페르소나 에이전트 (dashed, arrow) -->
<path d="M420 250 L470 250 L470 148 L508 148" fill="none" stroke="var(--pp-green)" stroke-width="1" stroke-dasharray="4 3" marker-end="url(#pp-arr)"/>

<!-- 페르소나 에이전트 → 다른 에이전트 (dashed, animated) -->
<line x1="566" y1="157" x2="566" y2="222" stroke="var(--pp-accent)" stroke-width="1" stroke-dasharray="5 3" class="pp-anim" marker-end="url(#pp-arr)"/>

</svg>
</div>

<style>
.persona-pipeline {
  --pp-inner: rgba(255,255,255,0.03);
  --pp-dim: #908caa;
  --pp-blue-bg: rgba(129,140,248,0.08);
  --pp-blue: #818cf8;
  --pp-blue-text: #c4b5fd;
  --pp-brown-bg: rgba(200,140,80,0.08);
  --pp-brown: #c88c50;
  --pp-brown-text: #e0c097;
  --pp-purple-bg: rgba(180,130,220,0.08);
  --pp-purple: #b482dc;
  --pp-purple-text: #d4b8e8;
  --pp-green-bg: rgba(109,208,160,0.08);
  --pp-green: #6dd0a0;
  --pp-green-text: #a0e8c8;
  --pp-accent-bg: rgba(129,140,248,0.15);
  --pp-accent: #818cf8;
  --pp-accent-text: #e0ddff;
}
:global(body:not([data-theme="dark"])) .persona-pipeline {
  --pp-inner: rgba(0,0,0,0.03);
  --pp-dim: #6e6a86;
  --pp-blue-bg: rgba(74,90,200,0.08);
  --pp-blue: #4a5ac8;
  --pp-blue-text: #3a4a98;
  --pp-brown-bg: rgba(180,110,40,0.08);
  --pp-brown: #b46e28;
  --pp-brown-text: #8a5420;
  --pp-purple-bg: rgba(140,90,180,0.08);
  --pp-purple: #8c5ab4;
  --pp-purple-text: #6a3a8c;
  --pp-green-bg: rgba(40,160,100,0.08);
  --pp-green: #28a064;
  --pp-green-text: #1a7048;
  --pp-accent-bg: rgba(74,90,200,0.15);
  --pp-accent: #4a5ac8;
  --pp-accent-text: #3a3a6a;
}
</style>
