---
interface Props {
  label?: string;
  text: string;
}
const { label, text } = Astro.props;
---

<figure class="note-block">
  <div class="note-block-chrome">
    <span class="note-dot note-dot-red"></span>
    <span class="note-dot note-dot-yellow"></span>
    <span class="note-dot note-dot-green"></span>
    {label && <span class="note-block-filename">{label}</span>}
  </div>
  <pre class="note-block-content">{text}</pre>
</figure>

<style>
.note-block {
  margin: 1.8rem 0;
  border-radius: 10px;
  overflow: hidden;
  background: var(--nb-body-bg);
  border: 1px solid var(--nb-outer-border);
  box-shadow: 0 6px 22px var(--nb-shadow);
}

.note-block-chrome {
  display: flex;
  align-items: center;
  gap: 7px;
  padding: 10px 14px;
  background: var(--nb-chrome-bg);
  border-bottom: 1px solid var(--nb-chrome-border);
  user-select: none;
}

.note-dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  display: inline-block;
  box-shadow: inset 0 0 0 0.5px rgba(0, 0, 0, 0.15);
}
.note-dot-red    { background: #ff5f57; }
.note-dot-yellow { background: #febc2e; }
.note-dot-green  { background: #28c840; }

.note-block-filename {
  margin-left: 14px;
  font-family: 'SF Mono', 'Consolas', 'Menlo', monospace;
  font-size: 0.78em;
  letter-spacing: 0.01em;
  color: var(--nb-filename);
}

.note-block-content {
  margin: 0;
  padding: 18px 22px 20px;
  background: transparent !important;
  border: none;
  font-family: 'SF Mono', 'Consolas', 'Menlo', monospace;
  font-size: 0.88em;
  line-height: 1.75;
  color: var(--nb-text);
  white-space: pre;
  overflow-x: auto;
}

.note-block {
  --nb-body-bg: #1c1d28;
  --nb-chrome-bg: #2a2b38;
  --nb-chrome-border: rgba(255, 255, 255, 0.05);
  --nb-outer-border: rgba(255, 255, 255, 0.07);
  --nb-shadow: rgba(0, 0, 0, 0.35);
  --nb-text: #cfcfdc;
  --nb-filename: #8a8a9a;
}

:global(body:not([data-theme="dark"])) .note-block {
  --nb-body-bg: #fafafb;
  --nb-chrome-bg: #ececef;
  --nb-chrome-border: rgba(0, 0, 0, 0.05);
  --nb-outer-border: rgba(0, 0, 0, 0.08);
  --nb-shadow: rgba(0, 0, 0, 0.06);
  --nb-text: #2c2c34;
  --nb-filename: #75757e;
}
</style>
